# Copy this file to .env and adjust values.
# If you're using docker-compose + Caddy, also set ORACLE_HOSTNAME below.

# --- Billing / auth ---

# Secret used to sign L402 macaroons for top-ups. Change in production.
ORACLE_MACAROON_SECRET=dev-change-me

# Token TTL (seconds) for L402 challenges (top-ups)
ORACLE_TOKEN_TTL_SECONDS=600

# API key prefix (identification only; not secret)
ORACLE_API_KEY_PREFIX=bmd_

# Wallet backend:
# - mock   => simulated wallet (recommended for local testing)
# - lnaddr => generates invoices via your Lightning Address (LNURL-pay)
ORACLE_WALLET_MODE=mock

# Required if WALLET_MODE=lnaddr
# Example: user@domain
ORACLE_LIGHTNING_ADDRESS=burlybakery53@walletofsatoshi.com

# DB (SQLite). If empty, uses ./btc_market_data_oracle.sqlite3
ORACLE_DB_PATH=

# Rate limit (simple in-memory MVP)
ORACLE_RL_ENABLED=1
ORACLE_RL_WINDOW_SECONDS=60
ORACLE_RL_MAX_ANON=60
ORACLE_RL_MAX_AUTH=2000

# Optional operator/admin token.
# When set, enables /v1/admin/* endpoints (protected via X-Admin-Token header).
ORACLE_ADMIN_TOKEN=

# Hostname used by Caddy (docker-compose). Example: oracle.yourdomain.com
ORACLE_HOSTNAME=

# Dev mode (optional)
ORACLE_DEV_MODE=1

# --- Market data sources ---

# live => fetch from exchanges
# mock => static values (useful for tests)
ORACLE_MARKET_MODE=live

ORACLE_BINANCE_BASE_URL=https://api.binance.com
ORACLE_BINANCE_SYMBOL=BTCUSDT
ORACLE_BINANCE_DEPTH_LIMIT=50

ORACLE_DERIBIT_BASE_URL=https://www.deribit.com
ORACLE_DERIBIT_INSTRUMENT=BTC-PERPETUAL

# Fetch intervals (seconds)
ORACLE_BINANCE_TICKER_INTERVAL_SECONDS=1
ORACLE_BINANCE_DEPTH_INTERVAL_SECONDS=1
ORACLE_DERIBIT_TICKER_INTERVAL_SECONDS=2
