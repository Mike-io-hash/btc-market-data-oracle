# Copy to .env and fill in values.

# Hosted oracle base URL
ORACLE_BASE_URL=https://oracle.satsgate.org

# Nostr Wallet Connect URL (keep this secret)
# Format: nostr+walletconnect://<wallet_pubkey>?relay=wss://...&secret=...
NWC_URL=

# Optional: reuse an existing API key (for querying without topping up each run)
ORACLE_API_KEY=

# --- Autopilot behavior ---

# Default: ON when NWC_URL exists.
# Set to 0 to disable automatic top-ups.
AUTO_TOPUP=1

# How often to query snapshot (seconds). Snapshot costs 2 verifications.
SNAPSHOT_INTERVAL_SECONDS=2

# How often to call reasoning endpoints + potentially top up (seconds)
REASONING_INTERVAL_SECONDS=300

# Purchase recommendation settings
LOOKBACK_HOURS=24
TARGET_DAYS=3
BUFFER_HOURS=12

# Guardrails
MAX_SINGLE_TOPUP_SATS=1000000
MAX_TOPUP_SATS_PER_DAY=10000000
TOPUP_COOLDOWN_SECONDS=300

# Internal (optional)
# ENV_PATH=./.env
# STATE_PATH=./.oracle_autopilot_state.json
